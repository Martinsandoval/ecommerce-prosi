# Copy to .env and adjust as needed, then run: docker compose up --build

# Postgres
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432

# API
API_PORT=3000
CACHE_TTL_MS=30000

# Web
WEB_PORT=3001
# Must be reachable from the end user's browser (baked into the client
# bundle at build time) - change this if you deploy behind a domain.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
