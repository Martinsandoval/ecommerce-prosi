NODE_ENV=development
PORT=3000

# Used by the API container/process
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce?schema=public

# In-memory response cache TTL for product reads (ms)
CACHE_TTL_MS=30000

# Used by docker-compose to provision the postgres container
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432
